{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile All",
            "type": "shell",
            "command": "javac -cp . GIUServer.java GIUClient.java",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
